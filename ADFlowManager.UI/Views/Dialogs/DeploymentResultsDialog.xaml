<ui:FluentWindow
    x:Class="ADFlowManager.UI.Views.Dialogs.DeploymentResultsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:ext="clr-namespace:ADFlowManager.UI.Extensions"
    Title="{ext:Localized DeployResults_Title}"
    Width="860"
    Height="640"
    MinWidth="700"
    MinHeight="480"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- === CONTENT === -->
        <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== SUMMARY BANNER ===== -->
            <Border
                Grid.Row="0"
                Background="#1A1F1F1F"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border
                        Grid.Column="0"
                        x:Name="SummaryIconBorder"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Background="#22C55E"
                        Margin="0,0,14,0">
                        <ui:SymbolIcon x:Name="SummaryIcon" Symbol="CheckmarkCircle24" FontSize="22"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <!-- Title / subtitle -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="SummaryTitle"
                            FontSize="15" FontWeight="SemiBold"
                            Foreground="#F5F5F5" />
                        <TextBlock
                            x:Name="SummarySubtitle"
                            FontSize="12"
                            Foreground="#A1A1AA"
                            Margin="0,3,0,0" />
                    </StackPanel>

                    <!-- Badges: success / warning / error -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Success badge -->
                        <Border
                            x:Name="SuccessBadge"
                            Background="#1622C55E"
                            BorderBrush="#4422C55E"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12,5"
                            Margin="0,0,6,0"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CheckmarkCircle16" FontSize="13" Foreground="#22C55E" Margin="0,0,5,0" />
                                <TextBlock x:Name="SuccessBadgeText" FontSize="13" FontWeight="SemiBold" Foreground="#22C55E" />
                            </StackPanel>
                        </Border>
                        <!-- Warning badge -->
                        <Border
                            x:Name="WarningBadge"
                            Background="#1AF59E0B"
                            BorderBrush="#4AF59E0B"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12,5"
                            Margin="0,0,6,0"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Warning16" FontSize="13" Foreground="#F59E0B" Margin="0,0,5,0" />
                                <TextBlock x:Name="WarningBadgeText" FontSize="13" FontWeight="SemiBold" Foreground="#F59E0B" />
                            </StackPanel>
                        </Border>
                        <!-- Error badge -->
                        <Border
                            x:Name="ErrorBadge"
                            Background="#1AEF4444"
                            BorderBrush="#4AEF4444"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12,5"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DismissCircle16" FontSize="13" Foreground="#EF4444" Margin="0,0,5,0" />
                                <TextBlock x:Name="ErrorBadgeText" FontSize="13" FontWeight="SemiBold" Foreground="#EF4444" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== RESULTS LIST ===== -->
            <ScrollViewer
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Each result card -->
                            <Border
                                Margin="0,0,0,8"
                                CornerRadius="8"
                                BorderThickness="1"
                                ClipToBounds="True">

                                <!-- Background / border tint via DataTrigger on StatusKind -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E252525" />
                                        <Setter Property="BorderBrush" Value="#3F3F46" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusKind}" Value="success">
                                                <Setter Property="Background" Value="#0A22C55E" />
                                                <Setter Property="BorderBrush" Value="#2C22C55E" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                <Setter Property="Background" Value="#0AF59E0B" />
                                                <Setter Property="BorderBrush" Value="#2CF59E0B" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                <Setter Property="Background" Value="#0AEAB308" />
                                                <Setter Property="BorderBrush" Value="#2CEAB308" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                                <Setter Property="Background" Value="#0AEF4444" />
                                                <Setter Property="BorderBrush" Value="#2CEF4444" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Left accent bar -->
                                        <ColumnDefinition Width="4" />
                                        <!-- Content -->
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 4px accent bar -->
                                    <Border Grid.Column="0" CornerRadius="8,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3F3F46" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="success">
                                                        <Setter Property="Background" Value="#22C55E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                        <Setter Property="Background" Value="#F59E0B" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                        <Setter Property="Background" Value="#EAB308" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                                        <Setter Property="Background" Value="#EF4444" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Card content -->
                                    <StackPanel Grid.Column="1" Margin="14,12,14,12">

                                        <!-- Row 1: Status icon + Package → Computer + Duration -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <Border
                                                Grid.Column="0"
                                                Width="32" Height="32"
                                                CornerRadius="8"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#3F3F46" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="success">
                                                                <Setter Property="Background" Value="#1422C55E" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                                <Setter Property="Background" Value="#14F59E0B" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                                <Setter Property="Background" Value="#14EAB308" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                                                <Setter Property="Background" Value="#14EF4444" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <ui:SymbolIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Symbol" Value="QuestionCircle24" />
                                                            <Setter Property="Foreground" Value="#71717A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="success">
                                                                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                                                    <Setter Property="Foreground" Value="#22C55E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                                    <Setter Property="Symbol" Value="Warning24" />
                                                                    <Setter Property="Foreground" Value="#F59E0B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                                    <Setter Property="Symbol" Value="LockClosed24" />
                                                                    <Setter Property="Foreground" Value="#EAB308" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                                                    <Setter Property="Symbol" Value="DismissCircle24" />
                                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                            </Border>

                                            <!-- Package → Computer + status label -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        Text="{Binding PackageName}"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Foreground="#F5F5F5" />
                                                    <TextBlock
                                                        Text=" v"
                                                        FontSize="12"
                                                        Foreground="#71717A" />
                                                    <TextBlock
                                                        Text="{Binding PackageVersion}"
                                                        FontSize="12"
                                                        Foreground="#71717A" />
                                                    <TextBlock
                                                        Text=" → "
                                                        FontSize="13"
                                                        Foreground="#52525B" />
                                                    <ui:SymbolIcon Symbol="Desktop24" FontSize="12" Margin="0,0,4,0" Foreground="#3B82F6" />
                                                    <TextBlock
                                                        Text="{Binding ComputerName}"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Foreground="#E4E4E7"
                                                        FontFamily="Consolas" />
                                                </StackPanel>

                                                <!-- Status label -->
                                                <TextBlock
                                                    Text="{Binding StatusLabel}"
                                                    FontSize="11"
                                                    Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#71717A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="success">
                                                                    <Setter Property="Foreground" Value="#22C55E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                                    <Setter Property="Foreground" Value="#F59E0B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                                    <Setter Property="Foreground" Value="#EAB308" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Duration badge -->
                                            <Border
                                                Grid.Column="2"
                                                Background="#1A3F3F46"
                                                BorderBrush="#3F3F46"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10,4"
                                                VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Clock24" FontSize="11" Foreground="#71717A" Margin="0,0,4,0" />
                                                    <TextBlock
                                                        Text="{Binding DurationLabel}"
                                                        FontSize="12"
                                                        Foreground="#A1A1AA" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Row 2: Error detail (only when non-empty) -->
                                        <Border
                                            Margin="44,6,0,0"
                                            Background="#141414"
                                            BorderBrush="#2D2D30"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,7"
                                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Info24" FontSize="12" Foreground="#71717A" Margin="0,0,7,0" VerticalAlignment="Top" />
                                                <TextBlock
                                                    Text="{Binding ErrorDetail}"
                                                    FontSize="12"
                                                    Foreground="#A1A1AA"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Row 3: Hint text (contextual advice) -->
                                        <Border
                                            Margin="44,5,0,0"
                                            Padding="10,7"
                                            CornerRadius="6"
                                            Visibility="{Binding HasHint, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#14EF4444" />
                                                    <Setter Property="BorderBrush" Value="#2CEF4444" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                            <Setter Property="Background" Value="#14F59E0B" />
                                                            <Setter Property="BorderBrush" Value="#2CF59E0B" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                            <Setter Property="Background" Value="#14EAB308" />
                                                            <Setter Property="BorderBrush" Value="#2CEAB308" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon FontSize="12" Margin="0,0,7,0" VerticalAlignment="Top">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Symbol" Value="Info24" />
                                                            <Setter Property="Foreground" Value="#EF4444" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                                    <Setter Property="Foreground" Value="#F59E0B" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                                    <Setter Property="Symbol" Value="Wrench24" />
                                                                    <Setter Property="Foreground" Value="#EAB308" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                                <TextBlock
                                                    Text="{Binding HintText}"
                                                    FontSize="12"
                                                    TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FCA5A5" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="warning">
                                                                    <Setter Property="Foreground" Value="#FDE68A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="locked">
                                                                    <Setter Property="Foreground" Value="#FEF08A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Row 4: Residual files warning -->
                                        <Border
                                            Margin="44,5,0,0"
                                            Background="#14EAB308"
                                            BorderBrush="#2CEAB308"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,7"
                                            Visibility="{Binding HasResidualFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="DocumentWarning24" FontSize="12" Foreground="#EAB308" Margin="0,0,7,0" VerticalAlignment="Top" />
                                                <TextBlock
                                                    Text="{Binding ResidualFilesText}"
                                                    FontSize="12"
                                                    Foreground="#FEF08A"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Row 5: Timeout offer checkbox (only for timeout results) -->
                                        <Border
                                            Margin="44,8,0,0"
                                            Background="#141E1E1E"
                                            BorderBrush="#2C8B5CF6"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,8"
                                            Visibility="{Binding ShowTimeoutOffer, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <CheckBox
                                                IsChecked="{Binding IncreaseTimeout, Mode=TwoWay}"
                                                Foreground="#DDD6FE"
                                                FontSize="12">
                                                <CheckBox.Content>
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Timer24" FontSize="12" Foreground="#8B5CF6" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding TimeoutOfferLabel}" Foreground="#DDD6FE" FontSize="12" />
                                                    </StackPanel>
                                                </CheckBox.Content>
                                            </CheckBox>
                                        </Border>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ===== FOOTER ===== -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    x:Name="TimeoutSavedText"
                    FontSize="12"
                    Foreground="#71717A"
                    VerticalAlignment="Center"
                    Visibility="Collapsed" />

                <ui:Button
                    Grid.Column="1"
                    Content="{ext:Localized DeployResults_Close}"
                    Appearance="Primary"
                    Click="CloseButton_Click"
                    Height="38"
                    Padding="32,0" />
            </Grid>
        </Grid>

        <!-- === TITLEBAR === -->
        <ui:TitleBar
            Grid.Row="0"
            Title="{ext:Localized DeployResults_Title}"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
