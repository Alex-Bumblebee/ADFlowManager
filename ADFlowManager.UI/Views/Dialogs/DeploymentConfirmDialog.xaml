<ui:FluentWindow
    x:Class="ADFlowManager.UI.Views.Dialogs.DeploymentConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:ext="clr-namespace:ADFlowManager.UI.Extensions"
    Title="{ext:Localized DeployConfirm_Title}"
    Width="760"
    Height="580"
    MinWidth="700"
    MinHeight="500"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- === CONTENT === -->
        <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== SUMMARY BANNER ===== -->
            <Border
                Grid.Row="0"
                Background="#1A8B5CF6"
                BorderBrush="#4C8B5CF6"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Background="#8B5CF6"
                        Margin="0,0,14,0">
                        <ui:SymbolIcon Symbol="Rocket24" FontSize="22" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="SummaryTitle"
                            FontSize="15" FontWeight="SemiBold"
                            Foreground="#F5F5F5" />
                        <TextBlock
                            x:Name="SummarySubtitle"
                            FontSize="12"
                            Foreground="#A1A1AA"
                            Margin="0,3,0,0" />
                    </StackPanel>

                    <!-- Total deployments badge -->
                    <Border
                        Grid.Column="2"
                        Background="#8B5CF6"
                        CornerRadius="20"
                        Padding="16,6"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TotalBadgeText"
                                FontSize="22" FontWeight="Bold"
                                Foreground="White" />
                            <TextBlock
                                Text="{ext:Localized DeployConfirm_Deployments}"
                                FontSize="12" FontWeight="SemiBold"
                                Foreground="#DDD6FE"
                                Margin="6,0,0,0"
                                VerticalAlignment="Bottom"
                                Padding="0,0,0,2" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== TWO COLUMNS: Packages + Computers ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- === LEFT: PACKAGES === -->
                <Border
                    Grid.Column="0"
                    Background="#1E1E1E"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Background="#161616"
                            Padding="14,10"
                            BorderBrush="#2D2D30"
                            BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Box24" FontSize="14" Foreground="#8B5CF6" Margin="0,0,8,0" />
                                <TextBlock
                                    x:Name="PackagesHeaderText"
                                    FontWeight="SemiBold" FontSize="12"
                                    Foreground="#A1A1AA" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="PackagesList" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Background="#252525"
                                            BorderBrush="#3F3F46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Package icon -->
                                                <Border
                                                    Grid.Column="0"
                                                    Width="34" Height="34"
                                                    CornerRadius="7"
                                                    Background="#3B2D5E"
                                                    Margin="0,0,10,0">
                                                    <ui:SymbolIcon Symbol="Box24" FontSize="17"
                                                                   Foreground="#8B5CF6"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock
                                                        Text="{Binding Name}"
                                                        FontWeight="SemiBold" FontSize="13"
                                                        Foreground="#F5F5F5"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <!-- Version -->
                                                        <Border Background="#1A8B5CF6" CornerRadius="4" Padding="5,2" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding Version}" FontSize="10" Foreground="#8B5CF6" FontWeight="SemiBold" />
                                                        </Border>
                                                        <!-- Type -->
                                                        <Border Background="#1A3B82F6" CornerRadius="4" Padding="5,2" Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding InstallerType}" FontSize="10" Foreground="#3B82F6" FontWeight="SemiBold" />
                                                        </Border>
                                                        <!-- Timeout -->
                                                        <Border Background="#1A52525B" CornerRadius="4" Padding="5,2">
                                                            <TextBlock Text="{Binding TimeoutLabel}" FontSize="10" Foreground="#71717A" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- === RIGHT: COMPUTERS === -->
                <Border
                    Grid.Column="2"
                    Background="#1E1E1E"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Background="#161616"
                            Padding="14,10"
                            BorderBrush="#2D2D30"
                            BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Desktop24" FontSize="14" Foreground="#3B82F6" Margin="0,0,8,0" />
                                <TextBlock
                                    x:Name="ComputersHeaderText"
                                    FontWeight="SemiBold" FontSize="12"
                                    Foreground="#A1A1AA" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ComputersList" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Background="#252525"
                                            BorderBrush="#2D2D30"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8"
                                            Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Border
                                                    Width="28" Height="28"
                                                    CornerRadius="6"
                                                    Background="#1E2D4A"
                                                    Margin="0,0,9,0">
                                                    <ui:SymbolIcon Symbol="Desktop24" FontSize="14"
                                                                   Foreground="#3B82F6"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock
                                                    Text="{Binding}"
                                                    FontSize="13"
                                                    Foreground="#E4E4E7"
                                                    FontFamily="Consolas"
                                                    VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== WARNING: IRREVERSIBLE ===== -->
            <Border
                Grid.Row="2"
                Background="#1AEF4444"
                BorderBrush="#EF4444"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" FontSize="14" Foreground="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock
                        Text="{ext:Localized DeployConfirm_Irreversible}"
                        FontSize="12"
                        Foreground="#FCA5A5"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ===== FOOTER BUTTONS ===== -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Estimated time -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Clock24" FontSize="13" Foreground="#52525B" Margin="0,0,6,0" />
                    <TextBlock
                        x:Name="EstimatedTimeText"
                        FontSize="12"
                        Foreground="#71717A" />
                </StackPanel>

                <ui:Button
                    Grid.Column="1"
                    Content="{ext:Localized Common_Cancel}"
                    Appearance="Secondary"
                    Click="CancelButton_Click"
                    Height="38"
                    Padding="24,0"
                    Margin="0,0,8,0" />

                <ui:Button
                    Grid.Column="2"
                    Content="{ext:Localized DeployConfirm_Deploy}"
                    Appearance="Primary"
                    Click="DeployButton_Click"
                    Height="38"
                    Padding="24,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Rocket24" />
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </Grid>

        <!-- === TITLEBAR === -->
        <ui:TitleBar
            Grid.Row="0"
            Title="{ext:Localized DeployConfirm_Title}"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
