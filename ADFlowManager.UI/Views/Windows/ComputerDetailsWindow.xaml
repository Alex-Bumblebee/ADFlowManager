<ui:FluentWindow
    x:Class="ADFlowManager.UI.Views.Windows.ComputerDetailsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:ADFlowManager.UI.Views.Windows"
    xmlns:ext="clr-namespace:ADFlowManager.UI.Extensions"
    Title="{ext:Localized ComputerDetails_Title}"
    Width="800"
    Height="650"
    d:DesignHeight="650"
    d:DesignWidth="800"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- === CONTENT === -->
        <Grid Grid.Row="1" Margin="24,0,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ============================================ -->
            <!-- HEADER : Icon + Info                         -->
            <!-- ============================================ -->
            <Border
                Grid.Row="0"
                Background="#1E1E1E"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border
                        Grid.Column="0"
                        Width="52"
                        Height="52"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Background="#3B2D5E"
                        CornerRadius="8">
                        <ui:SymbolIcon
                            Symbol="Desktop24"
                            FontSize="24"
                            Foreground="#8B5CF6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>

                    <!-- Name + OS + Status -->
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="ComputerNameText"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#F5F5F5" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock
                                x:Name="ComputerOSText"
                                FontSize="13"
                                Foreground="#A1A1AA"
                                Margin="0,0,12,0" />
                            <!-- Status badge -->
                            <Border
                                x:Name="StatusBadge"
                                VerticalAlignment="Center"
                                CornerRadius="4"
                                Padding="8,2">
                                <TextBlock
                                    x:Name="StatusText"
                                    FontSize="11"
                                    FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- TABS                                          -->
            <!-- ============================================ -->
            <TabControl
                Grid.Row="1"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">

                <!-- ====== Tab 1 : Général ====== -->
                <TabItem Header="{ext:Localized ComputerDetails_TabGeneral}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">

                            <!-- Row: Nom + Description -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{ext:Localized ComputerDetails_Name}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <ui:TextBox
                                        x:Name="DetailName"
                                        IsReadOnly="True"
                                        Background="#1E1E1E"
                                        Foreground="#F5F5F5"
                                        BorderBrush="#3F3F46"
                                        Height="40" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{ext:Localized ComputerDetails_Status}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <Border
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,0"
                                        Height="40"
                                        HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0" />
                                            <TextBlock
                                                x:Name="DetailStatus"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Description -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{ext:Localized ComputerDetails_Description}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                <ui:TextBox
                                    x:Name="DetailDescription"
                                    IsReadOnly="True"
                                    Background="#1E1E1E"
                                    Foreground="#A1A1AA"
                                    BorderBrush="#3F3F46"
                                    Height="40" />
                            </StackPanel>

                            <!-- Row: Emplacement + Géré par -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{ext:Localized ComputerDetails_Location}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <ui:TextBox
                                        x:Name="DetailLocation"
                                        IsReadOnly="True"
                                        Background="#1E1E1E"
                                        Foreground="#A1A1AA"
                                        BorderBrush="#3F3F46"
                                        Height="40" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{ext:Localized ComputerDetails_ManagedBy}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <ui:TextBox
                                        x:Name="DetailManagedBy"
                                        IsReadOnly="True"
                                        Background="#1E1E1E"
                                        Foreground="#A1A1AA"
                                        BorderBrush="#3F3F46"
                                        Height="40" />
                                </StackPanel>
                            </Grid>

                            <!-- Distinguished Name -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{ext:Localized ComputerDetails_DN}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                <ui:TextBox
                                    x:Name="DetailDN"
                                    IsReadOnly="True"
                                    Background="#1E1E1E"
                                    Foreground="#A1A1AA"
                                    BorderBrush="#3F3F46"
                                    Height="40" />
                            </StackPanel>

                            <!-- Row: Création + Modification -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{ext:Localized ComputerDetails_CreatedAt}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <ui:TextBox
                                        x:Name="DetailCreated"
                                        IsReadOnly="True"
                                        Background="#1E1E1E"
                                        Foreground="#A1A1AA"
                                        BorderBrush="#3F3F46"
                                        Height="40" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{ext:Localized ComputerDetails_ModifiedAt}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                    <ui:TextBox
                                        x:Name="DetailModified"
                                        IsReadOnly="True"
                                        Background="#1E1E1E"
                                        Foreground="#A1A1AA"
                                        BorderBrush="#3F3F46"
                                        Height="40" />
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ====== Tab 2 : Système ====== -->
                <TabItem Header="{ext:Localized ComputerDetails_TabSystem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{ext:Localized ComputerDetails_OperatingSystem}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                <ui:TextBox
                                    x:Name="DetailOS"
                                    IsReadOnly="True"
                                    Background="#1E1E1E"
                                    Foreground="#F5F5F5"
                                    BorderBrush="#3F3F46"
                                    Height="40" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{ext:Localized ComputerDetails_Version}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                <ui:TextBox
                                    x:Name="DetailOSVersion"
                                    IsReadOnly="True"
                                    Background="#1E1E1E"
                                    Foreground="#A1A1AA"
                                    BorderBrush="#3F3F46"
                                    Height="40" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{ext:Localized ComputerDetails_LastLogon}" FontSize="12" Foreground="#A1A1AA" Margin="0,0,0,4" />
                                <ui:TextBox
                                    x:Name="DetailLastLogon"
                                    IsReadOnly="True"
                                    Background="#1E1E1E"
                                    Foreground="#A1A1AA"
                                    BorderBrush="#3F3F46"
                                    Height="40" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ====== Tab 3 : Groupes ====== -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{ext:Localized ComputerDetails_TabGroups}" VerticalAlignment="Center" />
                            <Border
                                x:Name="GroupCountBadge"
                                Background="#3B2D5E"
                                CornerRadius="8"
                                Padding="6,2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    x:Name="GroupCountText"
                                    FontSize="11"
                                    Foreground="#8B5CF6"
                                    FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                    </TabItem.Header>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl
                            x:Name="GroupsList"
                            Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="#2D2D30"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Symbol="PeopleTeam16"
                                                FontSize="16"
                                                Foreground="#8B5CF6"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="{Binding}"
                                                FontSize="13"
                                                Foreground="#F5F5F5"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ============================================ -->
            <!-- FOOTER : Close                               -->
            <!-- ============================================ -->
            <Border
                Grid.Row="2"
                BorderBrush="#3F3F46"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,8,0,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:Button
                        Grid.Column="1"
                        Content="{ext:Localized ComputerDetails_Close}"
                        Appearance="Secondary"
                        Click="CloseButton_Click"
                        Height="36"
                        Padding="24,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- === TITLEBAR === -->
        <ui:TitleBar
            x:Name="TitleBar"
            Title="{ext:Localized ComputerDetails_Title}"
            Grid.Row="0"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
