<Page
    x:Class="ADFlowManager.UI.Views.Pages.PackageDeploymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:ADFlowManager.UI.Converters"
    xmlns:local="clr-namespace:ADFlowManager.UI.Views.Pages"
    xmlns:ext="clr-namespace:ADFlowManager.UI.Extensions"
    Title="Déploiement"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="24,8,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- === TOOLBAR === -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Title info -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border
                    Background="#8B5CF6"
                    CornerRadius="20"
                    Padding="16,8"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Box24" FontSize="18" Foreground="White" Margin="0,0,8,0" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                            <Run Text="{Binding SelectedPackageCount, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding PackageCount, Mode=OneWay}" />
                            <Run Text="{ext:Localized Packages_PackageCount}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border
                    Background="#3B82F6"
                    CornerRadius="20"
                    Padding="16,8"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Foreground="White" Margin="0,0,8,0" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                            <Run Text="{Binding SelectedComputerCount, Mode=OneWay}" />
                            <Run Text="{ext:Localized Packages_Selected}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button
                    Content="{ext:Localized CreatePackage_Create}"
                    Appearance="Secondary"
                    Command="{Binding CreatePackageCommand}"
                    Height="44"
                    Padding="16,0"
                    Margin="0,0,8,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Add24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button
                    Appearance="Secondary"
                    Command="{Binding LoadComputersCommand}"
                    ToolTip="{ext:Localized Computers_RefreshTooltip}"
                    Height="44"
                    Width="44"
                    Margin="0,0,8,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="ArrowSync24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button
                    Content="{ext:Localized Packages_Deploy}"
                    Appearance="Primary"
                    Command="{Binding DeployCommand}"
                    Height="44"
                    Padding="16,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Send24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- === MAIN CONTENT (Split) === -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <!-- === LEFT: PACKAGES LIST === -->
            <Border
                Grid.Column="0"
                Background="#1E1E1E"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True"
                MaxHeight="800"
                VerticalAlignment="Top">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border
                        Grid.Row="0"
                        Background="#161616"
                        Padding="16,12"
                        BorderBrush="#2D2D30"
                        BorderThickness="0,0,0,1">
                        <TextBlock
                            Text="{ext:Localized Packages_AvailablePackages}"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Foreground="#A1A1AA" />
                    </Border>

                    <!-- Search bar -->
                    <Border
                        Grid.Row="1"
                        Background="#161616"
                        Padding="10,8"
                        BorderBrush="#2D2D30"
                        BorderThickness="0,0,0,1">
                        <ui:TextBox
                            PlaceholderText="{ext:Localized Packages_SearchPlaceholder}"
                            Text="{Binding PackageSearchText, UpdateSourceTrigger=PropertyChanged}"
                            Background="#2D2D30"
                            Foreground="#F5F5F5"
                            BorderBrush="#3F3F46"
                            Height="34"
                            FontSize="12">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="Search24" Foreground="#8B5CF6" />
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                    </Border>

                    <!-- Package list with internal scroll -->
                    <ScrollViewer
                        Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Packages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="10,10,12,10"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="PackageItem_Click"
                                        BorderBrush="#2D2D30"
                                        BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1A8B5CF6" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2D30" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox
                                                Grid.Column="0"
                                                IsChecked="{Binding IsSelected}"
                                                VerticalAlignment="Top"
                                                Margin="4,2,8,0" />

                                            <!-- Package info -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock
                                                    Text="{Binding Package.Name}"
                                                    FontWeight="SemiBold"
                                                    FontSize="13"
                                                    Foreground="#F5F5F5" />
                                                <TextBlock
                                                    Text="{Binding Package.Description}"
                                                    FontSize="11"
                                                    Foreground="#71717A"
                                                    Margin="0,4,0,0"
                                                    TextWrapping="Wrap"
                                                    MaxHeight="40"
                                                    TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Border Background="#1A8B5CF6" CornerRadius="4" Padding="6,2" Margin="0,0,4,0"
                                                            Visibility="{Binding Package.Version, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding Package.Version}" FontSize="10" Foreground="#8B5CF6" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Background="#1A3B82F6" CornerRadius="4" Padding="6,2" Margin="0,0,4,0"
                                                            Visibility="{Binding Package.Category, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding Package.Category}" FontSize="10" Foreground="#3B82F6" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Background="#1A10B981" CornerRadius="4" Padding="6,2"
                                                            Visibility="{Binding Package.Installer.Type, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding Package.Installer.Type}" FontSize="10" Foreground="#10B981" FontWeight="SemiBold" />
                                                    </Border>
                                                    <!-- VULN-14 : Signature status badge -->
                                                    <Border CornerRadius="4" Padding="6,2" Margin="4,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#1AF59E0B" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Package.SignatureStatus}" Value="Valid">
                                                                        <Setter Property="Background" Value="#1A22C55E" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Package.SignatureStatus}" Value="Invalid">
                                                                        <Setter Property="Background" Value="#1AEF4444" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{ext:Localized Packages_Unsigned}" />
                                                                    <Setter Property="Foreground" Value="#F59E0B" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Package.SignatureStatus}" Value="Valid">
                                                                            <Setter Property="Text" Value="{ext:Localized Packages_SignatureValid}" />
                                                                            <Setter Property="Foreground" Value="#22C55E" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Package.SignatureStatus}" Value="Invalid">
                                                                            <Setter Property="Text" Value="{ext:Localized Packages_SignatureInvalid}" />
                                                                            <Setter Property="Foreground" Value="#EF4444" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer: Edit + Delete buttons -->
                    <Border
                        Grid.Row="3"
                        Background="#252525"
                        Padding="12,10"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button
                                Grid.Column="0"
                                Content="{ext:Localized Packages_Edit}"
                                Appearance="Secondary"
                                Command="{Binding EditPackageCommand}"
                                HorizontalAlignment="Stretch"
                                Height="32"
                                FontSize="12">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Edit24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:Button
                                Grid.Column="2"
                                Content="{ext:Localized Common_Delete}"
                                Appearance="Danger"
                                Command="{Binding DeletePackageCommand}"
                                Height="32"
                                Padding="14,0"
                                FontSize="12">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Delete24" />
                                </ui:Button.Icon>
                            </ui:Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- === RIGHT: TARGET COMPUTERS DataGrid === -->
            <Border
                Grid.Column="2"
                Background="#1E1E1E"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True"
                MaxHeight="800"
                VerticalAlignment="Top">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header with select/deselect -->
                    <Border
                        Grid.Row="0"
                        Background="#161616"
                        Padding="16,10"
                        BorderBrush="#2D2D30"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{ext:Localized Packages_TargetComputers}"
                                    FontWeight="SemiBold"
                                    FontSize="13"
                                    Foreground="#A1A1AA" />
                                <TextBlock
                                    Text="{ext:Localized Packages_SelectPCsForDeployment}"
                                    FontSize="11"
                                    Foreground="#52525B"
                                    Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button
                                    Content="{ext:Localized Packages_SelectAll}"
                                    Appearance="Secondary"
                                    Command="{Binding SelectAllComputersCommand}"
                                    Height="28"
                                    FontSize="11"
                                    Padding="10,0"
                                    Margin="0,0,6,0" />
                                <ui:Button
                                    Content="{ext:Localized Packages_DeselectAll}"
                                    Appearance="Secondary"
                                    Command="{Binding DeselectAllComputersCommand}"
                                    Height="28"
                                    FontSize="11"
                                    Padding="10,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Search bar for computers -->
                    <Border
                        Grid.Row="1"
                        Background="#161616"
                        Padding="10,8"
                        BorderBrush="#2D2D30"
                        BorderThickness="0,0,0,1">
                        <ui:TextBox
                            PlaceholderText="{ext:Localized Packages_PCSearchPlaceholder}"
                            Text="{Binding ComputerSearchText, UpdateSourceTrigger=PropertyChanged}"
                            Background="#2D2D30"
                            Foreground="#F5F5F5"
                            BorderBrush="#3F3F46"
                            Height="34"
                            FontSize="12">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="Search24" Foreground="#8B5CF6" />
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid
                        Grid.Row="2"
                        ItemsSource="{Binding Computers}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        GridLinesVisibility="None"
                        Background="Transparent"
                        Foreground="#F5F5F5"
                        BorderThickness="0"
                        RowHeaderWidth="0"
                        FontSize="13"
                        ScrollViewer.CanContentScroll="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        EnableRowVirtualization="True">

                        <DataGrid.Resources>
                            <!-- Row style -->
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="#2D2D30" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="MinHeight" Value="48" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2D2D30" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Cell style -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#F5F5F5" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border
                                                Background="Transparent"
                                                Padding="12,8">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="#F5F5F5" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Column header style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#161616" />
                                <Setter Property="Foreground" Value="#A1A1AA" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="BorderBrush" Value="#2D2D30" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- Checkbox -->
                            <DataGridTemplateColumn Header="" Width="48">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox
                                            IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Nom PC avec icône -->
                            <DataGridTemplateColumn Header="{ext:Localized Packages_ColName}" Width="2*" SortMemberPath="Computer.Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border
                                                Width="32" Height="32"
                                                CornerRadius="6"
                                                Background="#3B2D5E"
                                                Margin="0,0,10,0">
                                                <ui:SymbolIcon
                                                    Symbol="Desktop24"
                                                    FontSize="16"
                                                    Foreground="#8B5CF6"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock
                                                Text="{Binding Computer.Name}"
                                                FontWeight="SemiBold"
                                                Foreground="#F5F5F5"
                                                FontSize="13"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Système -->
                            <DataGridTemplateColumn Header="{ext:Localized Packages_ColSystem}" Width="*" SortMemberPath="Computer.OperatingSystem">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Computer.OperatingSystem}"
                                            Foreground="#A1A1AA"
                                            FontSize="13"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Description -->
                            <DataGridTemplateColumn Header="{ext:Localized Packages_ColDescription}" Width="*" SortMemberPath="Computer.Description">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="{Binding Computer.Description}"
                                            Foreground="#71717A"
                                            FontSize="13"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer: Progress / Count -->
                    <Border
                        Grid.Row="3"
                        Background="#252525"
                        Padding="16,10"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,1,0,0">
                        <Grid>
                            <!-- Normal: computer count -->
                            <TextBlock
                                FontSize="12"
                                Foreground="#71717A"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsDeploying, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Run Text="{Binding Computers.Count, Mode=OneWay}" FontWeight="SemiBold" Foreground="#8B5CF6" />
                                <Run Text="{ext:Localized Packages_AvailableComputers}" />
                            </TextBlock>

                            <!-- Deploying: progress -->
                            <StackPanel
                                Visibility="{Binding IsDeploying, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock
                                    Text="{Binding DeploymentStatus}"
                                    FontSize="12"
                                    Foreground="#A1A1AA"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,6" />
                                <ProgressBar
                                    Value="{Binding DeploymentProgress}"
                                    Height="6"
                                    Foreground="#8B5CF6"
                                    Background="#2D2D30" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Loader overlay -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Background="#CC0F0F0F"
            Panel.ZIndex="999"
            Visibility="{Binding IsLoadingComputers, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <ui:ProgressRing
                    IsIndeterminate="True"
                    Width="48"
                    Height="48"
                    Foreground="#8B5CF6"
                    Margin="0,0,0,16" />
                <TextBlock
                    Text="{ext:Localized Common_Loading}"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#F5F5F5"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
